              <h4 className="text-white text-xs font-bold uppercase tracking-wider mb-2">Packaging & Shipping</h4>
              <p className="text-[11px] text-neutral-500 leading-relaxed font-light">
                Trim, hot iron press, fold, barcode tag, bundle pack inside custom double-walled export cartons, and doorstep air/sea delivery.
              </p>
            </StaggerItem>
          </StaggerContainer>

        </div>
      </section>

      {/* 6. Strict B2B Quote Action Banner */}
      <section className="py-24 bg-black">
        <div className="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
          <AnimatedSection direction="up" delay={0.1}>
            <h2 className="text-3xl sm:text-5xl font-black tracking-tight text-white uppercase mb-6">
              SECURE YOUR MFG PROGRAM
            </h2>
          </AnimatedSection>
          <AnimatedSection direction="up" delay={0.2}>
            <p className="text-neutral-400 text-sm mb-10 max-w-lg mx-auto leading-relaxed font-light">
              Ready to construct your next activewear collection or get custom sublimated uniforms? Submit your RFQ details or tech packs.
            </p>
          </AnimatedSection>
          
          <AnimatedSection direction="up" delay={0.3} className="flex flex-col sm:flex-row justify-center gap-4">
            <Link href="/inquiry">
              <Button className="w-full sm:w-auto bg-white hover:bg-neutral-200 text-black font-semibold text-xs tracking-wider uppercase py-6 px-8 rounded-lg transition-all duration-300 cursor-pointer">
                Submit RFQ Details
                <Send className="ml-2 h-4 w-4" />
              </Button>
            </Link>
            <Link href="/about">
              <Button variant="outline" className="w-full sm:w-auto border-neutral-800 hover:bg-neutral-900 text-neutral-300 hover:text-white font-semibold text-xs tracking-wider uppercase py-6 px-8 rounded-lg transition-all duration-300 cursor-pointer">
                About Our Facility
              </Button>
            </Link>
          </AnimatedSection>
        </div>
      </section>

    </div>
  );
}
