async function getHomeData() {
  try {
    await connectDB();
    const categories = await Category.find({ parentCategory: null }).lean();
    const featuredProducts = await Product.find({ featured: true })
      .populate('category')
      .populate('subcategory')
      .limit(3)
      .lean();

    return {
      categories: categories.length > 0 ? JSON.parse(JSON.stringify(categories)) : STATIC_CATEGORIES,
      products: featuredProducts.length > 0 ? JSON.parse(JSON.stringify(featuredProducts)) : STATIC_PRODUCTS,
    };
  } catch (error) {
    console.error('Failed to load DB data, using fallbacks:', error);
    return {
      categories: STATIC_CATEGORIES,
      products: STATIC_PRODUCTS,
    };
  }
}

